# 共有ランキング（Supabase）を有効にする場合に設定。未設定なら端末内ランキングで動作。
# これらは「公開してよい」値（フロントに埋め込まれます）。秘密鍵は絶対に置かないこと。

VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...（anon public key）

# Cloudflare Turnstile を使う場合のサイトキー（任意・bot対策）
VITE_TURNSTILE_SITEKEY=0x4AAAAAAA...

# Google Analytics 4（Firebase連携）の測定ID。Firebaseの「ウェブアプリ」設定 or
# GA4管理画面で発行される G-XXXXXXXXXX。未設定ならアクセス計測オフ。
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
